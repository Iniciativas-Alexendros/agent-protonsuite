# =============================================================================
# Proton Bridge credentials (Mail)
# =============================================================================
# Email of the Proton account currently loaded in Bridge.
# With the official Proton Mail Beta app, this must match the signed-in account
# shown in the app; otherwise Bridge replies "no such user" even though the
# IMAP port (1143) is open.
PROTON_BRIDGE_USER=you@proton.me

# Bridge password (NOT your Proton account password).
# Find it in: Proton Mail Bridge > Account > Mailbox password
# Or run: protonmail-bridge-core --cli > info
# Alternativa: usar Pass para resolución JIT (ver PROTON_BRIDGE_PASS_PATH abajo).
PROTON_BRIDGE_PASS=replace-with-bridge-password

# En lugar de PROTON_BRIDGE_PASS, especifica una ruta en el password store de Pass.
# Si se define y PROTON_PASS_ENABLED=true, la contraseña se resuelve al vuelo.
# PROTON_BRIDGE_PASS_PATH=proton/bridge/password

# Bridge host. Use 127.0.0.1 when Bridge runs on the same machine as the MCP.
PROTON_BRIDGE_HOST=127.0.0.1
PROTON_BRIDGE_IMAP_PORT=1143
PROTON_BRIDGE_SMTP_PORT=1025

# Default "From" address used when sending. Must match an address configured in Bridge.
PROTON_MAIL_FROM=you@proton.me

# Bridge uses a self-signed TLS cert on localhost. Accept it? (true|false)
# Set to false only if you've imported Bridge's CA into your OS trust store.
PROTON_BRIDGE_TLS_INSECURE=true

# =============================================================================
# Proton Pass (via pass-cli)
# =============================================================================
# Enable Proton Pass integration (requires `pass` CLI installed).
PROTON_PASS_ENABLED=true
# Path to the password store directory (default: ~/.password-store).
PROTON_PASS_STORE_DIR=~/.password-store
# Optional: resolve Bridge password from Pass instead of env var.
# PROTON_PASS_BRIDGE_PATH=proton/bridge/password

# =============================================================================
# Proton Calendar (via Bridge CalDAV — not yet available)
# =============================================================================
# Enable when Bridge exposes CalDAV support.
# PROTON_CALENDAR_ENABLED=false

# =============================================================================
# Proton Drive (via REST API — requires OAuth 2.0 setup)
# =============================================================================
# Enable when OAuth credentials are configured.
# PROTON_DRIVE_ENABLED=false
# PROTON_DRIVE_REFRESH_TOKEN=

# =============================================================================
# MCP transport
# =============================================================================
# stdio | http
MCP_TRANSPORT=stdio

# HTTP mode only: bind address and port
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787

# HTTP mode only: bearer token required in Authorization header.
# Generate a strong random value: openssl rand -hex 32
MCP_AUTH_TOKEN=

# HTTP mode only: allowed Origin header values (CSV). Leave empty to allow none.
# Example: https://command-center.afiladocs.com,https://claude.ai
MCP_ALLOWED_ORIGINS=

# =============================================================================
# Agent behaviour
# =============================================================================
# true = present the plan without applying changes (recommended for first runs).
AGENT_DRY_RUN=true
# Maximum emails inspected during an organization pass.
AGENT_MAX_INSPECT_EMAILS=1000
# Minimum confidence (0-1) for the agent to accept a classification proposal.
AGENT_MIN_CONFIDENCE=0.6

# =============================================================================
# Alerts
# =============================================================================
# Optional webhook URL for security/content alerts (POST, JSON).
ALERT_WEBHOOK_URL=
# Minimum severity that triggers file and webhook output: info | warning | alert | critical
ALERT_MIN_SEVERITY=warning
# Directory for structured alert and audit logs.
ALERT_LOG_DIR=logs
# false to disable the alert subsystem entirely.
ALERTS_ENABLED=true

# =============================================================================
# Logging
# =============================================================================
# error | warn | info | debug
LOG_LEVEL=info
