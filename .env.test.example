# =============================================================================
# Integration test credentials
# =============================================================================
# Copy to .env.test and fill in real values.
# NEVER commit .env.test — it contains live Proton Bridge credentials.

# Set to 'true' to enable integration tests against real Proton Bridge.
PROTON_INTEGRATION_TEST=true

# Proton Bridge credentials (same as .env.example for mail tests)
PROTON_BRIDGE_USER=your-email@proton.me
PROTON_BRIDGE_PASS=your-bridge-mailbox-password

# Bridge connection (defaults shown)
PROTON_BRIDGE_HOST=127.0.0.1
PROTON_BRIDGE_IMAP_PORT=1143
PROTON_BRIDGE_SMTP_PORT=1025
PROTON_BRIDGE_TLS_INSECURE=true
