{
  "name": "@alexendros/protonsuite-agent",
  "private": true,
  "version": "0.7.0",
  "mcpName": "io.github.Alexendros/protonsuite-agent",
  "description": "Agente Proton Suite con MCP server embebido: Mail (Bridge IMAP/SMTP), Pass (pass-cli), Calendar y Drive — 14+ tools, auto-configuración, organización inteligente y alertas de seguridad.",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "protonsuite-agent": "dist/agent-cli.js",
    "protonsuite-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "server.json",
    "docs",
    "playbooks",
    "connectors"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iniciativas-Alexendros/agent-protonsuite.git"
  },
  "homepage": "https://github.com/Iniciativas-Alexendros/agent-protonsuite#readme",
  "bugs": {
    "url": "https://github.com/Iniciativas-Alexendros/agent-protonsuite/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proton-suite",
    "proton-mail",
    "proton-pass",
    "proton-calendar",
    "proton-drive",
    "proton-bridge",
    "imap",
    "smtp",
    "pass-cli",
    "email",
    "ai-agent",
    "agent-tool",
    "password-manager",
    "spam-detection",
    "email-automation",
    "email-organization",
    "document-management"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage && bash scripts/update-coverage-badge.sh --skip-run",
    "coverage:badge": "bash scripts/update-coverage-badge.sh",
    "coverage:check": "bash scripts/update-coverage-badge.sh --check",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e:local": "bash scripts/e2e-greenmail.sh",
    "smoke": "bash scripts/smoke.sh",
    "agent:setup": "node dist/agent-cli.js setup",
    "agent:organize": "node dist/agent-cli.js organize",
    "agent:pass-audit": "node dist/agent-cli.js pass-audit",
    "agent:suite-status": "node dist/agent-cli.js suite-status",
    "agent:drive-audit": "node dist/agent-cli.js drive-audit",
    "agent:drive-organize": "node dist/agent-cli.js drive-organize",
    "agent:drive-list": "node dist/agent-cli.js drive-list",
    "agent:drive-download": "node dist/agent-cli.js drive-download",
    "agent:drive-upload": "node dist/agent-cli.js drive-upload",
    "agent:suite-manage": "node dist/agent-cli.js suite-manage",
    "license-check": "license-checker --direct --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;MIT-0;MPL-2.0;AGPL-3.0;GPL-3.0;LGPL-3.0;CC-BY-3.0;CC0-1.0;(MIT OR EUPL-1.1+)'",
    "license-check:prod": "license-checker --direct --production --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;MIT-0;AGPL-3.0;GPL-3.0;LGPL-3.0;(MIT OR EUPL-1.1+)'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "knip": "knip --no-exit-code",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^65.0.1",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.5.2",
    "semantic-release": "^25.0.7",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
